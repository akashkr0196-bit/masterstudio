# Database Config
# For PostgreSQL: postgresql://username:password@localhost:5432/dbname
# For SQLite: sqlite:///./masterstudio.db
DATABASE_URL=sqlite:///./masterstudio.db

# Storage configuration (AWS S3 or Cloudflare R2)
# If empty, storage_manager will fall back to local storage directory.
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_ENDPOINT_URL=

# AI face matching
# Higher detector size improves small/side faces but uses more CPU.
AI_FACE_DET_SIZE=960
# Lower threshold returns more matches; raise it if unrelated faces appear.
AI_MATCH_THRESHOLD=0.45
AI_FALLBACK_MATCH_THRESHOLD=0.38
AI_RELATIVE_MATCH_MARGIN=0.18
AI_GUEST_FACE_CANDIDATES=2
AI_MAX_MATCHES=300

# Guest OTP delivery
# Paste your real Fast2SMS authorization key in backend/.env, not in git.
FAST2SMS_API_KEY=
SMS_PROVIDER=Fast2SMS
SMS_DAILY_LIMIT=50
MAX_UPLOAD_SIZE_MB=75
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Keep false/empty in production. Use true only for local testing without SMS credits.
OTP_DEBUG_LOGGING=false
