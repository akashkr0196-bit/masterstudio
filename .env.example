VITE_PUBLIC_APP_URL=https://your-domain.com
VITE_API_BASE_URL=https://your-domain.com/api
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173,http://127.0.0.1:5173
APP_ENV=production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_TTL_SECONDS=604800
SUPER_ADMIN_EMAIL=admin@masterstudio.in
SUPER_ADMIN_PASSWORD=change-this-before-launch
PASSWORD_ITERATIONS=240000
LOGIN_WINDOW_SECONDS=900
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_SECONDS=900
# Production: PostgreSQL only. Run `alembic upgrade head` before starting the API.
DATABASE_URL=postgresql+psycopg2://masterstudio_user:strong-password@localhost:5432/masterstudio
AUTO_CREATE_TABLES=false
ENABLE_PGVECTOR=1
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DEFAULT_STORAGE_QUOTA_GB=50
BACKUP_RETENTION_DAYS=30
CLEANUP_FAILED_JOB_DAYS=7
OTP_DEBUG_LOGGING=false
FAST2SMS_API_KEY=
SMS_PROVIDER=Fast2SMS
SMS_DAILY_LIMIT=50
MAX_UPLOAD_SIZE_MB=75
# Local development/testing can override with:
# APP_ENV=development
# DATABASE_URL=sqlite:///./masterstudio.db
# AUTO_CREATE_TABLES=true
LOCAL_STORAGE_DIR=static/uploads
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_ENDPOINT_URL=
